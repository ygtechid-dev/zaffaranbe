                                "bookings",
                                "1",
                                "cancel"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Admin - Dashboard",
            "item": [
                {
                    "name": "Get Dashboard Stats",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/admin/dashboard/stats",
                            "host": [
