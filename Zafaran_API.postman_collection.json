                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "customer",
                                "bookings"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Booking Detail",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/customer/bookings/1",
                            "host": [
                                "{{base_url}}"
